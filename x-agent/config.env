# =============================================================================
# X Agent VS — Configuration
# =============================================================================
#
# This file is read by the setup/start scripts and Docker Compose.
# It contains all configuration needed for the X Agent service.
#
# For local testing:
#   source x-agent/config.env
#   ./x-agent/scripts/setup.sh
#
# =============================================================================

# ---------------------------------------------------------------------------
# Network (derived from branch name in GHA; set manually for local usage)
# ---------------------------------------------------------------------------
# NETWORK="testnet"

# ---------------------------------------------------------------------------
# Veranad CLI account name
# ---------------------------------------------------------------------------
USER_ACC="org-vs-admin"

# ---------------------------------------------------------------------------
# Organization — parent service
# Set to the public URL of the organization agent (K8s or local).
# The admin API is used to request Service credentials.
# ---------------------------------------------------------------------------
ORG_VS_PUBLIC_URL="${ORG_VS_PUBLIC_URL:-}"
ORG_VS_PUBLIC_URL="${ORG_VS_PUBLIC_URL%/}"
ORG_VS_ADMIN_URL="${ORG_VS_ADMIN_URL:-http://localhost:3000}"
ORG_VS_ADMIN_URL="${ORG_VS_ADMIN_URL%/}"

# ---------------------------------------------------------------------------
# VS Agent image and ports (local development)
# Use different ports than other services to avoid collision.
# ---------------------------------------------------------------------------
VS_AGENT_IMAGE="${VS_AGENT_IMAGE:-veranalabs/vs-agent:latest}"
VS_AGENT_CONTAINER_NAME="x-agent"
VS_AGENT_ADMIN_PORT="3030"
VS_AGENT_PUBLIC_PORT="3031"

# ---------------------------------------------------------------------------
# Service details
# These appear in the Service credential issued by organization.
# ---------------------------------------------------------------------------
SERVICE_NAME="X Agent"
SERVICE_TYPE="AIAgent"
SERVICE_DESCRIPTION="AI agent for publishing and managing posts on X (Twitter)"
SERVICE_LOGO_URL="https://hologram.zone/images/x-white.svg"
SERVICE_MIN_AGE="0"
SERVICE_TERMS="https://hologram.zone/page/terms-of-service/"
SERVICE_PRIVACY="https://hologram.zone/page/privacy-policy/"

# ---------------------------------------------------------------------------
# Chatbot configuration (hologram-generic-ai-agent)
# ---------------------------------------------------------------------------
CHATBOT_IMAGE="${CHATBOT_IMAGE:-io2060/hologram-generic-ai-agent-app:v1.12.0}"
CHATBOT_PORT="3003"

# LLM
LLM_PROVIDER="openai"
OPENAI_MODEL="gpt-5.4-mini"
OPENAI_API_KEY="${OPENAI_API_KEY:-}"

# RAG
RAG_PROVIDER="langchain"
RAG_DOCS_PATH="/app/rag/docs"

# Memory
AGENT_MEMORY_BACKEND="redis"
AGENT_MEMORY_WINDOW="20"

# Credential authentication
# AnonCreds credential definition ID used to authenticate users.
# This is the credDef registered by organization.
# CREDENTIAL_DEFINITION_ID="${CREDENTIAL_DEFINITION_ID:-}"
CREDENTIAL_DEFINITION_ID="did:webvh:QmNY4etokEQci6nm7e93UJZU5WELC1vYdCyQBtDjMsFHWo:avatar.vs.hologram.zone/resources/zQmPrd9gAk23ACigPxKzX1nd1Nf7qe4kvUUwm8gXEaJUhaY"

# ---------------------------------------------------------------------------
# X (Twitter) MCP Server (x-autonomous-mcp via supergateway)
# ---------------------------------------------------------------------------
X_MCP_IMAGE="${X_MCP_IMAGE:-io2060/x-autonomous-mcp:latest}"
X_MCP_PORT="8000"
X_MCP_URL="http://x-mcp:${X_MCP_PORT}/mcp"

# X (Twitter) API Credentials
# Get these from https://developer.x.com/en/portal/dashboard
# OAuth 1.0a (required for write operations: posting, liking, retweeting)
X_API_KEY="${X_API_KEY:-}"
X_API_SECRET="${X_API_SECRET:-}"
X_ACCESS_TOKEN="${X_ACCESS_TOKEN:-}"
X_ACCESS_TOKEN_SECRET="${X_ACCESS_TOKEN_SECRET:-}"
# OAuth 2.0 Bearer Token (used for read operations: search, lookup)
X_BEARER_TOKEN="${X_BEARER_TOKEN:-}"

# X MCP Safety rails (optional — defaults shown)
X_MCP_MAX_REPLIES="8"
X_MCP_MAX_ORIGINALS="10"
X_MCP_MAX_LIKES="20"
X_MCP_MAX_RETWEETS="5"
X_MCP_MAX_FOLLOWS="10"
X_MCP_MAX_UNFOLLOWS="10"
X_MCP_MAX_DELETES="5"

# TOON encoding — set to false for JSON output (required for programmatic use)
X_MCP_TOON="false"
# Compact responses — strip verbose fields to save tokens
X_MCP_COMPACT="true"
# Engagement deduplication — prevent duplicate likes/replies/retweets/follows
X_MCP_DEDUP="true"
# Protected accounts — comma-separated usernames that cannot be unfollowed
# X_MCP_PROTECTED_ACCOUNTS="friend1,friend2"

# ---------------------------------------------------------------------------
# PostgreSQL
# ---------------------------------------------------------------------------
POSTGRES_PASSWORD="${POSTGRES_PASSWORD:-changeme}"
POSTGRES_USER="x_agent_db"
POSTGRES_DB="x-agent"

# ---------------------------------------------------------------------------
# Logging
# ---------------------------------------------------------------------------
LOG_LEVEL="info"
