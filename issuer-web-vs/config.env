# =============================================================================
# Issuer Web VS — Configuration
# =============================================================================
#
# This file is read by the setup scripts and GHA workflow.
# It contains all configuration needed for the Issuer Web child service.
#
# For local testing:
#   source issuer-web-vs/config.env
#   ./issuer-web-vs/scripts/setup.sh
#
# =============================================================================

# ---------------------------------------------------------------------------
# Network (derived from branch name in GHA; set manually for local usage)
# ---------------------------------------------------------------------------
# NETWORK="testnet"

# ---------------------------------------------------------------------------
# Veranad CLI account name
# ---------------------------------------------------------------------------
USER_ACC="org-vs-admin"

# ---------------------------------------------------------------------------
# Organization VS — parent service
# Set to the public URL of the organization-vs agent (K8s or local).
# The admin API is used to request Service credentials.
# ---------------------------------------------------------------------------
ORG_VS_PUBLIC_URL="${ORG_VS_PUBLIC_URL:-}"
ORG_VS_PUBLIC_URL="${ORG_VS_PUBLIC_URL%/}"
ORG_VS_ADMIN_URL="${ORG_VS_ADMIN_URL:-http://localhost:3000}"
ORG_VS_ADMIN_URL="${ORG_VS_ADMIN_URL%/}"

# ---------------------------------------------------------------------------
# VS Agent image and ports (local development)
# Use different ports than other services to avoid collision.
# ---------------------------------------------------------------------------
VS_AGENT_IMAGE="${VS_AGENT_IMAGE:-veranalabs/vs-agent:latest}"
VS_AGENT_CONTAINER_NAME="issuer-web-vs"
VS_AGENT_ADMIN_PORT="3004"
VS_AGENT_PUBLIC_PORT="3005"

# ---------------------------------------------------------------------------
# Service details
# These appear in the Service credential issued by organization-vs.
# ---------------------------------------------------------------------------
SERVICE_NAME="Avatar Web Issuer"
SERVICE_TYPE="IssuerService"
SERVICE_DESCRIPTION="Avatar credential issuer chatbot"
SERVICE_LOGO_URL="https://2060.io/images/avatar.jpg"
SERVICE_MIN_AGE="0"
SERVICE_TERMS="https://hologram.zone/page/terms-of-service/"
SERVICE_PRIVACY="https://hologram.zone/page/privacy-policy/"

# ---------------------------------------------------------------------------
# Custom schema base ID
# Must match the schema deployed by organization-vs.
# ---------------------------------------------------------------------------
CUSTOM_SCHEMA_BASE_ID="avatar"

# ---------------------------------------------------------------------------
# AnonCreds
# Set to "true" to issue AnonCreds credentials (requires cred-def setup).
# ---------------------------------------------------------------------------
ENABLE_ANONCREDS="true"
ANONCREDS_NAME="avatar"
ANONCREDS_VERSION="1.0"
ANONCREDS_SUPPORT_REVOCATION="false"

# ---------------------------------------------------------------------------
# Web app configuration
# ---------------------------------------------------------------------------
ISSUER_WEB_PORT="4001"

# Logging level (debug, info, warn, error)
LOG_LEVEL="info"
