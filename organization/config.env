# =============================================================================
# Organization — Configuration
# =============================================================================
#
# This file is read by the setup scripts and GHA workflow.
# It contains all configuration needed for the Organization service.
#
# For local testing:
#   source organization/config.env
#   ./organization/scripts/setup.sh
#
# =============================================================================

# ---------------------------------------------------------------------------
# Network (derived from branch name in GHA; set manually for local usage)
# ---------------------------------------------------------------------------
# NETWORK="testnet"

# ---------------------------------------------------------------------------
# Veranad CLI account name
# ---------------------------------------------------------------------------
USER_ACC="org-vs-admin"

# ---------------------------------------------------------------------------
# VS Agent image and ports (local development)
# ---------------------------------------------------------------------------
VS_AGENT_IMAGE="${VS_AGENT_IMAGE:-veranalabs/vs-agent:latest}"
VS_AGENT_CONTAINER_NAME="organization"
VS_AGENT_ADMIN_PORT="3000"
VS_AGENT_PUBLIC_PORT="3001"

# ---------------------------------------------------------------------------
# Expose admin API publicly (K8s only)
# When "true", the workflow deploys a standalone ingress at
# admin.organization.vs.hologram.zone
# exposing only the W3C issuance endpoint (/v1/vt/issue-credential) and
# Swagger UI (/api). The full admin API is NOT exposed.
# ---------------------------------------------------------------------------
EXPOSE_ADMIN_API="true"

# ---------------------------------------------------------------------------
# Organization details
# These appear in the Organization credential issued by the ECS TR.
# ---------------------------------------------------------------------------
ORG_NAME="2060 OÜ"
ORG_COUNTRY="EE"
ORG_LOGO_URL="https://2060.io/images/logo-squared.svg"
ORG_REGISTRY_ID="16853041"
ORG_ADDRESS="Harju maakond, Tallinn, Kesklinna linnaosa, Ahtri tn 12, 15551"

# ---------------------------------------------------------------------------
# Service details
# These appear in the Service credential self-issued by the VS Agent.
# ---------------------------------------------------------------------------
SERVICE_NAME="2060 OÜ Hologram Trust Registry"
SERVICE_TYPE="TrustRegistry"
SERVICE_DESCRIPTION="Trust Registry for Hologram Verifiable Services"
SERVICE_LOGO_URL="https://2060.io/images/logo-squared.svg"
SERVICE_MIN_AGE="0"
SERVICE_TERMS="https://hologram.zone/page/terms-of-service/"
SERVICE_PRIVACY="https://hologram.zone/page/privacy-policy/"

# ---------------------------------------------------------------------------
# Trust Registry configuration
# ---------------------------------------------------------------------------

# Schemas to register under the organization's trust registry.
# Each entry defines a JSON schema file, a base ID for the VTJSC service entry,
# and optional AnonCreds credential definition settings.
#
# Fields per entry:
#   file            — path to the JSON schema file (relative to repo root)
#   baseId          — identifier used in DID Document service entries (e.g. "avatar-jsc-vp")
#   anonCredsName   — name for the AnonCreds credential definition (omit to skip)
#   anonCredsVersion— version for the AnonCreds credential definition
SCHEMAS_CONFIG='[
  {"file": "organization/avatar-schema.json",    "baseId": "avatar",   "anonCredsName": "avatar",   "anonCredsVersion": "1.0"},
  {"file": "organization/passport-schema.json", "baseId": "passport", "anonCredsName": "passport", "anonCredsVersion": "1.0"}
]'

# Ecosystem Governance Framework document
# Digest is auto-calculated at runtime if left empty.
EGF_DOC_URL="https://verana-labs.github.io/governance-docs/EGF/example.pdf"
# EGF_DOC_DIGEST=""

# Trust Registry URL (defaults to the public ingress URL from deployment.yaml)
# TR_REGISTRY_URL="https://my-service.example.com"

# ---------------------------------------------------------------------------
# AnonCreds (optional — set to true to enable dual W3C + AnonCreds issuance)
# ---------------------------------------------------------------------------
ENABLE_ANONCREDS="true"
ANONCREDS_SUPPORT_REVOCATION="false"
