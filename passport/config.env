# =============================================================================
# Passport Issuer VS — Configuration
# =============================================================================
#
# This file is read by the setup scripts and GHA workflow.
# It contains all configuration needed for the Passport Issuer child service.
#
# For local testing:
#   source passport/config.env
#   ./passport/scripts/setup.sh
#
# =============================================================================

# ---------------------------------------------------------------------------
# Network (derived from branch name in GHA; set manually for local usage)
# ---------------------------------------------------------------------------
# NETWORK="testnet"

# ---------------------------------------------------------------------------
# Veranad CLI account name
# ---------------------------------------------------------------------------
USER_ACC="org-vs-admin"

# ---------------------------------------------------------------------------
# Organization — parent service
# Set to the public URL of the organization agent (K8s or local).
# The admin API is used to request Service credentials.
# ---------------------------------------------------------------------------
ORG_VS_PUBLIC_URL="${ORG_VS_PUBLIC_URL:-}"
ORG_VS_PUBLIC_URL="${ORG_VS_PUBLIC_URL%/}"
ORG_VS_ADMIN_URL="${ORG_VS_ADMIN_URL:-http://localhost:3000}"
ORG_VS_ADMIN_URL="${ORG_VS_ADMIN_URL%/}"

# ---------------------------------------------------------------------------
# VS Agent image and ports (local development)
# Use different ports than organization and avatar to avoid collision.
# ---------------------------------------------------------------------------
VS_AGENT_IMAGE="${VS_AGENT_IMAGE:-veranalabs/vs-agent:latest}"
VS_AGENT_CONTAINER_NAME="passport"
VS_AGENT_ADMIN_PORT="3004"
VS_AGENT_PUBLIC_PORT="3005"

# ---------------------------------------------------------------------------
# Service details
# These appear in the Service credential issued by organization.
# ---------------------------------------------------------------------------
SERVICE_NAME="Passport Issuer"
SERVICE_TYPE="IssuerService"
SERVICE_DESCRIPTION="Passport credential issuer — NFC reading and liveness verification"
SERVICE_LOGO_URL="https://hologram.zone/images/passport.jpg"
SERVICE_MIN_AGE="0"
SERVICE_TERMS="https://hologram.zone/page/terms-of-service/"
SERVICE_PRIVACY="https://hologram.zone/page/privacy-policy/"

# ---------------------------------------------------------------------------
# Custom schema base ID
# Must match the passport schema deployed by organization.
# ---------------------------------------------------------------------------
CUSTOM_SCHEMA_BASE_ID="passport"

# ---------------------------------------------------------------------------
# AnonCreds
# Set to "true" to create an AnonCreds credential definition for issuance.
# ---------------------------------------------------------------------------
ENABLE_ANONCREDS="true"
ANONCREDS_NAME="passport"
ANONCREDS_VERSION="1.0"
ANONCREDS_SUPPORT_REVOCATION="false"

# ---------------------------------------------------------------------------
# Gov ID Issuer chatbot (hologram-gov-id-issuer-vs)
# ---------------------------------------------------------------------------
CHATBOT_IMAGE="io2060/hologram-gov-id-issuer-app:v1.4.4-dev.1"
CHATBOT_PORT="2903"

# Session persistence
# Local: use the PostgreSQL container defined in docker-compose
# K8s:   PostgreSQL connection string (e.g., postgresql://user:pass@host:5432/db)
DATABASE_URL="postgresql://passport:passport@localhost:5432/passport"

# ---------------------------------------------------------------------------
# Backend services — shared infrastructure
# For local dev, point to external shared instances.
# For K8s, these resolve to in-cluster services.
# ---------------------------------------------------------------------------
VISION_URL="${VISION_URL:-https://vision.demos.dev.2060.io}"
WEBRTC_SERVER_URL="${WEBRTC_SERVER_URL:-https://webrtc.demos.dev.2060.io}"

# ID verification timeout (seconds)
ID_VERIFICATION_TIMEOUT_SECONDS="900"

# Logging level (1=error, 2=warn, 3=debug)
LOG_LEVEL="3"
